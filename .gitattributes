# Keep the app byte-identical and correct across macOS / Windows checkouts.

# Default: normalize text to LF in the repo.
* text=auto eol=lf

# Windows launcher must stay CRLF so double-clicking works on Windows.
*.bat text eol=crlf

# macOS launcher and shell scripts stay LF.
*.command text eol=lf
*.sh       text eol=lf

# Binary assets — never touch line endings.
*.woff2 binary
*.png   binary
*.jpg   binary
*.ico   binary
